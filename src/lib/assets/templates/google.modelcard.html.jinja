<!DOCTYPE html>
{#- ===== MACROS ===== -#}

{% macro render_graphic(graph) %}
  <div class="chart-card">
    {% if "://" in graph.image %}
      <img src="{{ graph.image }}" alt="{{ graph.name }}" />
    {% else %}
      <img src="data:image/jpeg;base64,{{ graph.image }}" alt="{{ graph.name }}" />
    {% endif %}
    {% if graph.name %}<div class="chart-caption">{{ graph.name }}</div>{% endif %}
  </div>
{% endmacro %}

{% macro render_graphics(graphics) %}
  <div class="charts-grid">
    {% for graph in graphics %}
      {{ render_graphic(graph) }}
    {% endfor %}
  </div>
{% endmacro %}

{% macro render_license(license) %}
  {% if license.identifier %}{{ license.identifier }}{% endif %}{% if license.custom_text %}{{ license.custom_text }}{% endif %}
{% endmacro %}

{% macro metric_name(metric) %}
{{ metric.type }}{% if metric.threshold %}@{{ metric.threshold }}{% endif %}{% if metric.slice %}, {{ metric.slice }}{% endif %}
{% endmacro %}

{% macro metric_value(metric) %}
{{ metric.value }}{% if metric.confidence_interval %} ({{ metric.confidence_interval.lower_bound }}, {{ metric.confidence_interval.upper_bound }}){% endif %}
{% endmacro %}

{#- ===== DOCUMENT ===== -#}
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Model Card{% if model_details.name %} — {{ model_details.name }}{% endif %}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --white: #ffffff;
    --gray-50: #fafafa;
    --gray-100: #f5f5f5;
    --gray-150: #ededed;
    --gray-200: #e5e5e5;
    --gray-300: #d4d4d4;
    --gray-400: #a3a3a3;
    --gray-500: #737373;
    --gray-600: #525252;
    --gray-700: #404040;
    --gray-800: #262626;
    --gray-900: #171717;
    --gray-950: #0a0a0a;
    --teal-50: #f0fdfa;
    --teal-100: #ccfbf1;
    --teal-200: #99f6e4;
    --teal-400: #2dd4bf;
    --teal-500: #14b8a6;
    --teal-600: #0d9488;
    --teal-700: #0f766e;
    --teal-800: #115e59;
    --teal-900: #134e4a;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-mono: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 2px 8px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --shadow-lg: 0 4px 16px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
    --radius: 8px;
    --radius-lg: 12px;
  }

  html { scroll-behavior: smooth; scroll-padding-top: 5rem; }

  body {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.7;
    color: var(--gray-800);
    background: var(--gray-50);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* --- NAV --- */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 260px;
    height: 100vh;
    background: var(--white);
    border-right: 1px solid var(--gray-200);
    padding: 2rem 0;
    overflow-y: auto;
    z-index: 100;
  }

  nav .nav-brand {
    padding: 0 1.5rem 1.5rem;
    border-bottom: 1px solid var(--gray-150);
    margin-bottom: 1rem;
  }

  nav .nav-brand span {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-400);
  }

  nav .nav-brand h2 {
    font-size: 14px;
    font-weight: 700;
    color: var(--gray-900);
    margin-top: 4px;
  }

  nav ul { list-style: none; }

  nav ul li a {
    display: block;
    padding: 7px 1.5rem;
    font-size: 13px;
    font-weight: 500;
    color: var(--gray-500);
    text-decoration: none;
    transition: all 0.15s ease;
    border-left: 2px solid transparent;
  }

  nav ul li a:hover {
    color: var(--gray-900);
    background: var(--gray-50);
  }

  nav ul li a.active {
    color: var(--teal-700);
    border-left-color: var(--teal-600);
    background: var(--teal-50);
  }

  /* --- MAIN --- */
  main {
    margin-left: 260px;
    max-width: 860px;
    padding: 0 3rem 6rem;
  }

  /* --- HERO --- */
  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--gray-200);
    margin-bottom: 3rem;
  }

  .hero .badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-500);
    background: var(--gray-100);
    border: 1px solid var(--gray-200);
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: 36px;
    font-weight: 800;
    color: var(--gray-950);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 17px;
    color: var(--gray-500);
    max-width: 600px;
    line-height: 1.7;
  }

  .hero-meta {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .hero-meta .meta-item {
    font-size: 13px;
    color: var(--gray-400);
  }

  .hero-meta .meta-item strong {
    color: var(--teal-700);
    font-weight: 600;
  }

  /* --- SECTIONS --- */
  section {
    margin-bottom: 3.5rem;
  }

  section > h2 {
    font-size: 22px;
    font-weight: 700;
    color: var(--gray-950);
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--teal-600);
  }

  section > p.section-desc {
    color: var(--gray-500);
    font-size: 14px;
    margin-bottom: 1.5rem;
  }

  h3 {
    font-size: 16px;
    font-weight: 700;
    color: var(--gray-800);
    margin: 2rem 0 0.75rem;
  }

  h4 {
    font-size: 14px;
    font-weight: 600;
    color: var(--gray-700);
    margin: 1.5rem 0 0.5rem;
  }

  p { margin-bottom: 0.75rem; }

  /* --- CARDS --- */
  .card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  .card + .card { margin-top: 1rem; }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .card-grid .card + .card { margin-top: 0; }

  .card h4 {
    margin-top: 0;
    font-size: 15px;
    font-weight: 700;
    color: var(--gray-900);
  }

  .card p {
    font-size: 14px;
    color: var(--gray-600);
  }

  /* --- DETAIL LIST --- */
  .detail-list {
    margin-top: 1rem;
  }

  .detail-row {
    display: flex;
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-100);
    font-size: 14px;
    gap: 1rem;
  }

  .detail-row:last-child { border-bottom: none; }

  .detail-label {
    width: 160px;
    flex-shrink: 0;
    font-weight: 600;
    color: var(--gray-500);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-top: 1px;
  }

  .detail-value {
    color: var(--gray-800);
    flex: 1;
  }

  .detail-value a {
    color: var(--gray-700);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--gray-300);
  }

  .detail-value a:hover {
    color: var(--teal-700);
    text-decoration-color: var(--teal-400);
  }

  /* --- TAGS --- */
  .tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--gray-100);
    color: var(--gray-600);
    border: 1px solid var(--gray-200);
    margin: 2px 3px 2px 0;
  }

  .tag.sensitive {
    background: var(--teal-700);
    color: var(--teal-50);
    border-color: var(--teal-800);
  }

  /* --- TABLES --- */
  .table-wrap {
    margin-top: 1rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  thead th {
    text-align: left;
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-400);
    background: var(--teal-50);
    border-bottom: 1px solid var(--gray-200);
  }

  tbody td {
    padding: 11px 16px;
    color: var(--gray-700);
    border-bottom: 1px solid var(--gray-100);
  }

  tbody tr:last-child td { border-bottom: none; }

  tbody tr:hover { background: var(--gray-50); }

  .mono {
    font-family: var(--font-mono);
    font-size: 13px;
  }

  /* --- CHARTS GRID --- */
  .charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .chart-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .chart-card img {
    width: 100%;
    height: auto;
    display: block;
  }

  .chart-card .chart-caption {
    padding: 10px 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--gray-500);
    border-top: 1px solid var(--gray-150);
  }

  /* --- CALLOUT --- */
  .callout {
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    border-left: 3px solid var(--teal-500);
    background: var(--gray-100);
    margin: 1rem 0;
    font-size: 14px;
    color: var(--gray-700);
  }

  .callout strong { color: var(--gray-900); }

  /* --- CODE BLOCK --- */
  pre {
    background: var(--gray-900);
    color: var(--gray-300);
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-lg);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.6;
    margin: 1rem 0;
    white-space: pre-wrap;
  }

  code {
    font-family: var(--font-mono);
    font-size: 13px;
  }

  /* --- LIST --- */
  ul.clean {
    list-style: none;
    padding: 0;
  }

  ul.clean li {
    position: relative;
    padding: 6px 0 6px 20px;
    font-size: 14px;
    color: var(--gray-700);
  }

  ul.clean li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal-500);
  }

  /* --- RISK CARD --- */
  .risk-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-left: 3px solid var(--teal-500);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-top: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .risk-card .risk-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--gray-900);
    margin-bottom: 0.75rem;
  }

  .risk-card .risk-section-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-400);
    margin: 1rem 0 0.25rem;
  }

  .risk-card p {
    font-size: 14px;
    color: var(--gray-600);
    margin-bottom: 0.5rem;
  }

  /* --- FOOTER --- */
  footer {
    margin-left: 260px;
    max-width: 860px;
    padding: 2rem 3rem;
    border-top: 1px solid var(--gray-200);
    font-size: 12px;
    color: var(--gray-400);
  }

  /* --- MOBILE --- */
  .mobile-header {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: var(--white);
    border-bottom: 1px solid var(--gray-200);
    z-index: 200;
    align-items: center;
    padding: 0 1.25rem;
  }

  .mobile-header button {
    background: none;
    border: 1px solid var(--gray-200);
    border-radius: 6px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-600);
  }

  .mobile-header .mh-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--gray-900);
    margin-left: 12px;
  }

  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 99;
  }

  @media (max-width: 860px) {
    nav {
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      box-shadow: var(--shadow-lg);
    }

    nav.open { transform: translateX(0); }

    .nav-overlay.open { display: block; }

    .mobile-header { display: flex; }

    main {
      margin-left: 0;
      padding: 4.5rem 1.25rem 4rem;
      max-width: 100%;
    }

    footer {
      margin-left: 0;
      padding: 2rem 1.25rem;
    }

    .hero h1 { font-size: 28px; }

    .hero { padding-top: 1rem; }

    .detail-row { flex-direction: column; gap: 2px; }
    .detail-label { width: auto; }

    .card-grid { grid-template-columns: 1fr; }
    .charts-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- Mobile Header -->
<div class="mobile-header">
  <button onclick="toggleNav()">Menu</button>
  <span class="mh-title">{% if model_details.name %}{{ model_details.name }}{% else %}Model Card{% endif %}</span>
</div>

<!-- Overlay -->
<div class="nav-overlay" id="navOverlay" onclick="toggleNav()"></div>

<!-- Sidebar Navigation -->
<nav id="sidebar">
  <div class="nav-brand">
    <span>Model Card</span>
    {% if model_details.name %}<h2>{{ model_details.name }}</h2>{% endif %}
  </div>
  <ul>
    <li><a href="#overview" class="active">Overview</a></li>
    {% if model_details %}
      <li><a href="#model-details">Model Details</a></li>
    {% endif %}
    {% if model_parameters.model_architecture or model_parameters.input_format or model_parameters.input_format_map or model_parameters.output_format or model_parameters.output_format_map %}
      <li><a href="#parameters">Parameters</a></li>
    {% endif %}
    {% if model_parameters.data %}
      <li><a href="#datasets">Datasets</a></li>
    {% endif %}
    {% if quantitative_analysis.performance_metrics or quantitative_analysis.graphics %}
      <li><a href="#quantitative-analysis">Quantitative Analysis</a></li>
    {% endif %}
    {% if considerations and (considerations.users or considerations.use_cases or considerations.limitations or considerations.tradeoffs or considerations.ethical_considerations) %}
      <li><a href="#considerations">Considerations</a></li>
    {% endif %}
    {% if model_details.references or model_details.citations %}
      <li><a href="#references">References</a></li>
    {% endif %}
  </ul>
</nav>

<!-- Main Content -->
<main>

  <!-- HERO -->
  <section class="hero" id="overview">
    <div class="badge">Model Card</div>
    <h1>{% if model_details.name %}{{ model_details.name }}{% else %}Model Card{% endif %}</h1>
    {% if model_details.overview %}
      <p>{{ model_details.overview }}</p>
    {% endif %}
    <div class="hero-meta">
      {% if model_details.version and model_details.version.name %}
        <div class="meta-item"><strong>Version</strong> {{ model_details.version.name }}</div>
      {% endif %}
      {% if model_details.version and model_details.version.date %}
        <div class="meta-item"><strong>Updated</strong> {{ model_details.version.date }}</div>
      {% endif %}
      {% if model_details.licenses %}
        <div class="meta-item"><strong>License</strong> {% for license in model_details.licenses %}{{ render_license(license) }}{% if not loop.last %}, {% endif %}{% endfor %}</div>
      {% endif %}
    </div>
  </section>

  {# ===== MODEL DETAILS ===== #}
  {% if model_details %}
  <section id="model-details">
    <h2>Model Details</h2>

    <div class="detail-list">
      {% if model_details.version and model_details.version.name %}
        <div class="detail-row">
          <div class="detail-label">Version</div>
          <div class="detail-value"><code class="mono">{{ model_details.version.name }}</code></div>
        </div>
      {% endif %}
      {% if model_details.version and model_details.version.date %}
        <div class="detail-row">
          <div class="detail-label">Date</div>
          <div class="detail-value">{{ model_details.version.date }}</div>
        </div>
      {% endif %}
      {% if model_details.version and model_details.version.diff %}
        <div class="detail-row">
          <div class="detail-label">Diff</div>
          <div class="detail-value">{{ model_details.version.diff }}</div>
        </div>
      {% endif %}
      {% if model_details.licenses %}
        <div class="detail-row">
          <div class="detail-label">License</div>
          <div class="detail-value">{% for license in model_details.licenses %}{{ render_license(license) }}{% if not loop.last %}, {% endif %}{% endfor %}</div>
        </div>
      {% endif %}
      {% if model_details.path %}
        <div class="detail-row">
          <div class="detail-label">Path</div>
          <div class="detail-value"><code class="mono">{{ model_details.path }}</code></div>
        </div>
      {% endif %}
    </div>

    {% if model_details.owners %}
      <h3>Owners</h3>
      <div class="card-grid">
        {% for owner in model_details.owners %}
          <div class="card">
            <h4>{{ owner.name }}</h4>
            {% if owner.contact %}<p><a href="mailto:{{ owner.contact }}">{{ owner.contact }}</a></p>{% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if model_details.documentation %}
      <h3>Documentation</h3>
      <p style="font-size:14px; color: var(--gray-600);">{{ model_details.documentation }}</p>
    {% endif %}
  </section>
  {% endif %}

  {# ===== MODEL PARAMETERS ===== #}
  {% if model_parameters.model_architecture or model_parameters.input_format or model_parameters.input_format_map or model_parameters.output_format or model_parameters.output_format_map %}
  <section id="parameters">
    <h2>Model Parameters</h2>

    <div class="detail-list">
      {% if model_parameters.model_architecture %}
        <div class="detail-row">
          <div class="detail-label">Architecture</div>
          <div class="detail-value">{{ model_parameters.model_architecture }}</div>
        </div>
      {% endif %}
      {% if model_parameters.input_format %}
        <div class="detail-row">
          <div class="detail-label">Input Format</div>
          <div class="detail-value">{{ model_parameters.input_format }}</div>
        </div>
      {% endif %}
      {% if model_parameters.output_format %}
        <div class="detail-row">
          <div class="detail-label">Output Format</div>
          <div class="detail-value">{{ model_parameters.output_format }}</div>
        </div>
      {% endif %}
    </div>

    {% if model_parameters.input_format_map %}
      <h3>Input Fields</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Field</th>
              <th>Type</th>
            </tr>
          </thead>
          <tbody>
            {% for kv in model_parameters.input_format_map %}
              <tr><td>{{ kv.key }}</td><td><span class="tag">{{ kv.value }}</span></td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}

    {% if model_parameters.output_format_map %}
      <h3>Output Fields</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Field</th>
              <th>Type</th>
            </tr>
          </thead>
          <tbody>
            {% for kv in model_parameters.output_format_map %}
              <tr><td>{{ kv.key }}</td><td><span class="tag">{{ kv.value }}</span></td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </section>
  {% endif %}

  {# ===== DATASETS ===== #}
  {% if model_parameters.data %}
  <section id="datasets">
    <h2>Datasets</h2>

    {% for dataset in model_parameters.data %}
      <div class="card" style="margin-top: 1rem;">
        {% if dataset.name %}<h4>{{ dataset.name }}</h4>{% endif %}
        {% if dataset.description %}<p>{{ dataset.description }}</p>{% endif %}
        {% if dataset.link %}
          <p style="margin-top: 0.5rem;"><a href="{{ dataset.link }}" target="_blank">{{ dataset.link }}</a></p>
        {% endif %}
        {% if dataset.sensitive and dataset.sensitive.sensitive_data %}
          <div style="margin-top: 0.75rem;">
            <span style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:var(--gray-400);">Sensitive Features</span><br>
            {% for feature in dataset.sensitive.sensitive_data %}
              <span class="tag sensitive">{{ feature }}</span>
            {% endfor %}
          </div>
        {% endif %}
        {% if dataset.graphics and dataset.graphics.collection %}
          <h4 style="margin-top: 1.25rem;">Data Distribution</h4>
          {% if dataset.graphics.description %}
            <p style="font-size: 14px; color: var(--gray-500);">{{ dataset.graphics.description }}</p>
          {% endif %}
          <div class="charts-grid" style="margin-top: 0.75rem;">
            {% for graph in dataset.graphics.collection %}
              {{ render_graphic(graph) }}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </section>
  {% endif %}

  {# ===== QUANTITATIVE ANALYSIS ===== #}
  {% if quantitative_analysis.performance_metrics or quantitative_analysis.graphics %}
  <section id="quantitative-analysis">
    <h2>Quantitative Analysis</h2>

    {% if quantitative_analysis.performance_metrics %}
      <h3>Performance Metrics</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Metric</th>
              <th>Slice</th>
              <th>Value</th>
              <th>Confidence Interval</th>
            </tr>
          </thead>
          <tbody>
            {% for metric in quantitative_analysis.performance_metrics %}
              <tr>
                <td>{{ metric.type }}{% if metric.threshold %}@{{ metric.threshold }}{% endif %}</td>
                <td>{% if metric.slice %}{{ metric.slice }}{% else %}&mdash;{% endif %}</td>
                <td><strong>{{ metric.value }}</strong></td>
                <td class="mono">{% if metric.confidence_interval %}{{ metric.confidence_interval.lower_bound }} &ndash; {{ metric.confidence_interval.upper_bound }}{% else %}&mdash;{% endif %}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}

    {% if quantitative_analysis.graphics and quantitative_analysis.graphics.collection %}
      <h3>Performance Charts</h3>
      {% if quantitative_analysis.graphics.description %}
        <p style="font-size: 14px; color: var(--gray-500);">{{ quantitative_analysis.graphics.description }}</p>
      {% endif %}
      {{ render_graphics(quantitative_analysis.graphics.collection) }}
    {% endif %}
  </section>
  {% endif %}

  {# ===== CONSIDERATIONS ===== #}
  {% if considerations and (considerations.users or considerations.use_cases or considerations.limitations or considerations.tradeoffs or considerations.ethical_considerations) %}
  <section id="considerations">
    <h2>Considerations</h2>

    {% if considerations.users %}
      <h3>Intended Users</h3>
      <ul class="clean">
        {% for user in considerations.users %}
          <li>{{ user.description }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if considerations.use_cases %}
      <h3>Use Cases</h3>
      <ul class="clean">
        {% for use_case in considerations.use_cases %}
          <li>{{ use_case.description }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if considerations.limitations %}
      <h3>Limitations</h3>
      <ul class="clean">
        {% for limitation in considerations.limitations %}
          <li>{{ limitation.description }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if considerations.tradeoffs %}
      <h3>Tradeoffs</h3>
      <ul class="clean">
        {% for tradeoff in considerations.tradeoffs %}
          <li>{{ tradeoff.description }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if considerations.ethical_considerations %}
      <h3>Ethical Considerations</h3>
      {% for risk in considerations.ethical_considerations %}
        <div class="risk-card">
          <div class="risk-name">{{ risk.name }}</div>
          {% if risk.mitigation_strategy %}
            <div class="risk-section-label">Mitigation Strategy</div>
            <p>{{ risk.mitigation_strategy }}</p>
          {% endif %}
        </div>
      {% endfor %}
    {% endif %}
  </section>
  {% endif %}

  {# ===== REFERENCES & CITATIONS ===== #}
  {% if model_details.references or model_details.citations %}
  <section id="references">
    <h2>References &amp; Citations</h2>

    {% if model_details.references %}
      <h3>References</h3>
      <ul class="clean">
        {% for ref in model_details.references %}
          <li><a href="{{ ref.reference }}" target="_blank">{{ ref.reference }}</a></li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if model_details.citations %}
      <h3>Citations</h3>
      {% for citation in model_details.citations %}
        <pre>{{ citation.citation }}</pre>
      {% endfor %}
    {% endif %}
  </section>
  {% endif %}

</main>

<footer>
  Model Card{% if model_details.name %} &middot; {{ model_details.name }}{% endif %}{% if model_details.version and model_details.version.name %} &middot; {{ model_details.version.name }}{% endif %}
</footer>

<script>
  function toggleNav() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('navOverlay').classList.toggle('open');
  }

  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('nav ul li a');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => link.classList.remove('active'));
        const active = document.querySelector(`nav a[href="#${entry.target.id}"]`);
        if (active) active.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -75% 0px' });

  sections.forEach(section => observer.observe(section));
</script>

</body>
</html>
